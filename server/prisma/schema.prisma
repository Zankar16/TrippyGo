generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  creatorMode  Boolean  @default(false)
  travelDna    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  
  trips              Trip[]
  conversations      Conversation[]
  documents          Document[]
  sharedTrips        SharedTrip[]
  collaborations     TripCollaborator[]
  votes              Vote[]
  creatorGuides      CreatorGuide[]
  sessions           Session[]
  passwordResets     PasswordReset[]
  expenses           Expense[]
  notifications      Notification[]
  notificationPrefs  NotificationPreference?
  systemLogs         SystemLog[]
  exportLogs         ExportLog[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trip {
  id          String   @id @default(uuid())
  userId      String
  title       String
  destination String
  startDate   DateTime?
  endDate     DateTime?
  budget      Float    @default(0)
  tripType    String   @default("Leisure")
  flagEmoji   String   @default("🌍")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  user             User               @relation(fields: [userId], references: [id])
  days             ItineraryDay[]
  collaborators    TripCollaborator[]
  votes            Vote[]
  creatorGuides    CreatorGuide[]
  expenses         Expense[]
  weatherAlerts    WeatherAlert[]
  exportLogs       ExportLog[]
  
  @@index([userId])
}

model ItineraryDay {
  id        String   @id @default(uuid())
  tripId    String
  dayNumber Int
  date      DateTime?
  theme     String?
  createdAt DateTime @default(now())
  
  trip          Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items         ItineraryItem[]
  weatherAlerts WeatherAlert[]
  
  @@index([tripId])
}

model ItineraryItem {
  id            String   @id @default(uuid())
  dayId         String
  type          String   // flight hotel activity meal
  name          String
  startTime     String?
  endTime       String?
  duration      String?
  price         Float    @default(0)
  currency      String   @default("USD")
  location      String?
  latitude      Float?
  longitude     Float?
  notes         String?
  instaScore    Int?
  photoTip      String?
  shootingTime  String?
  imageUrl      String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  
  day            ItineraryDay    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  votes          Vote[]
  budgetSuggests BudgetSuggestion[]
  affiliateLinks AffiliateLink[]
  
  @@index([dayId])
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String
  userId      String
  amount      Float
  currency    String   @default("USD")
  category    String   // flights, accommodation, meals, activities, misc
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
}

model BudgetSuggestion {
  id              String   @id @default(uuid())
  itineraryItemId String
  message         String
  savingsAmount   Float
  accepted        Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  item ItineraryItem @relation(fields: [itineraryItemId], references: [id], onDelete: Cascade)

  @@index([itineraryItemId])
}

model WeatherAlert {
  id                  String   @id @default(uuid())
  tripId              String
  dayId               String
  severity            String   // yellow, red
  condition           String
  message             String
  suggestedActivityId String?
  createdAt           DateTime @default(now())
  
  trip Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day  ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([dayId])
}

model Conversation {
  id          String   @id @default(uuid())
  userId      String
  title       String   @default("New Conversation")
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
  
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // user or assistant
  content        String
  responseType   String?  // text places recommendations weather
  responseData   Json?
  createdAt      DateTime @default(now())
  
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
}

model Document {
  id                 String   @id @default(uuid())
  userId             String
  filename           String
  originalName       String
  mimeType           String
  size               Int
  filePath           String
  verificationStatus String   @default("pending")
  uploadedAt         DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId])
}

model SharedTrip {
  id          String   @id @default(uuid())
  tripId      String
  createdBy   String
  shareId     String   @unique
  expiresAt   DateTime?
  viewCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  
  @@index([shareId])
}

model TripCollaborator {
  id            String   @id @default(uuid())
  tripId        String
  userId        String?
  invitedEmail  String
  role          String   @default("viewer")
  inviteStatus  String   @default("pending")
  joinedAt      DateTime?
  createdAt     DateTime @default(now())
  
  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
}

model Vote {
  id         String   @id @default(uuid())
  tripId     String
  userId     String
  activityId String
  voteValue  Int      @default(0)
  createdAt  DateTime @default(now())
  
  trip     Trip          @relation(fields: [tripId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  activity ItineraryItem @relation(fields: [activityId], references: [id])
  
  @@unique([tripId, userId, activityId])
}

model CreatorGuide {
  id               String   @id @default(uuid())
  userId           String
  tripId           String?
  title            String
  description      String?
  coverImage       String?
  tags             String[] @default([])
  cloneCount       Int      @default(0)
  viewCount        Int      @default(0)
  affiliateRevenue Float    @default(0)
  status           String   @default("published")
  publishedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  
  user           User            @relation(fields: [userId], references: [id])
  trip           Trip?           @relation(fields: [tripId], references: [id])
  affiliateLinks AffiliateLink[]
}

model AffiliateLink {
  id             String   @id @default(uuid())
  guideId        String
  itineraryItemId String
  url            String
  provider       String
  createdAt      DateTime @default(now())
  
  guide CreatorGuide  @relation(fields: [guideId], references: [id], onDelete: Cascade)
  item  ItineraryItem @relation(fields: [itineraryItemId], references: [id], onDelete: Cascade)
  commissions Commission[]

  @@index([guideId])
  @@index([itineraryItemId])
}

model Commission {
  id              String   @id @default(uuid())
  affiliateLinkId String
  amount          Float
  currency        String   @default("USD")
  earnedAt        DateTime @default(now())
  status          String   @default("pending") // pending, paid
  
  link AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@index([affiliateLinkId])
}

model CatalogItem {
  id           String @id @default(uuid())
  city         String
  name         String
  type         String
  description  String?
  imageUrl     String?
  price        Float  @default(0)
  duration     String?
  rating       Float  @default(0)
  instaScore   Int    @default(0)
  photoTip     String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([city])
}

model NewSpot {
  id           String  @id @default(uuid())
  name         String
  country      String
  city         String
  imageUrl     String?
  instaScore   Int     @default(0)
  isTrending   Boolean @default(false)
  photoTip     String?
  shootingTime String?
  composition  String?
  scoreBreakdown Json?
  price        Float   @default(0)
  duration     String  @default("2 hours")
  createdAt    DateTime @default(now())
}

model SystemLog {
  id           String   @id @default(uuid())
  userId       String?
  level        String   // info, error, warning
  message      String
  stackTrace   String?
  endpoint     String?
  statusCode   Int?
  responseTime Int?     // ms
  createdAt    DateTime @default(now())
  
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  type          String   // trip_invite, collaborator_join, weather_alert, trip_shared, guide_published
  message       String
  isRead        Boolean  @default(false)
  referenceId   String?  // tripId, activityId, etc.
  referenceType String?
  createdAt     DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  emailEnabled  Boolean  @default(true)
  inAppEnabled  Boolean  @default(true)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExportLog {
  id         String   @id @default(uuid())
  tripId     String
  userId     String
  format     String   // pdf, link
  createdAt  DateTime @default(now())
  
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
}
